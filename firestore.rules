rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Missing active field = allowed; only explicit false is blocked
    function accountActive() {
      return signedIn()
        && (
          !userExists()
          || !('active' in userDoc())
          || userDoc().active != false
        );
    }

    function isPlatformAdmin() {
      return accountActive()
        && userExists()
        && userDoc().role == 'platform_admin';
    }

    function isShopAdmin() {
      return accountActive()
        && userExists()
        && userDoc().role == 'shop_admin'
        && userDoc().companyId is string
        && userDoc().companyId.size() > 0;
    }

    function sameCompany(companyId) {
      return accountActive()
        && userExists()
        && userDoc().companyId == companyId;
    }

    function withoutCompany() {
      return !('companyId' in resource.data)
        || resource.data.companyId == null
        || resource.data.companyId == '';
    }

    // Users may update their own non-security fields
    function selfSafeUserUpdate() {
      return request.auth.uid == userId
        && accountActive()
        && request.resource.data.get('role', null) == resource.data.get('role', null)
        && request.resource.data.get('companyId', null) == resource.data.get('companyId', null)
        && request.resource.data.get('active', true) == resource.data.get('active', true);
    }

    // Staff join: attach self to a shop via invite code
    function joiningShop() {
      return request.auth.uid == userId
        && accountActive()
        && withoutCompany()
        && request.resource.data.companyId is string
        && request.resource.data.companyId.size() > 0
        && request.resource.data.role in ['tech', 'shop_admin']
        && request.resource.data.get('active', true) != false;
    }

    function shopAdminManagingUser() {
      return isShopAdmin()
        && resource.data.get('companyId', '') == userDoc().companyId
        && resource.data.get('role', '') != 'platform_admin'
        && request.resource.data.get('role', null) != 'platform_admin'
        && (
          request.resource.data.get('companyId', null) == resource.data.companyId
          || request.resource.data.get('companyId', null) == null
          || request.resource.data.get('companyId', null) == ''
        );
    }

    match /users/{userId} {
      allow read: if accountActive() && (
        request.auth.uid == userId
        || isPlatformAdmin()
        || (isShopAdmin() && resource.data.get('companyId', '') == userDoc().companyId)
      );

      allow create: if signedIn() && request.auth.uid == userId;

      allow update: if accountActive() && (
        isPlatformAdmin()
        || selfSafeUserUpdate()
        || joiningShop()
        || shopAdminManagingUser()
      );
    }

    match /companies/{companyId} {
      // Open enough for invite-code query + shop members + platform admin
      allow read, list: if accountActive();

      allow create, delete: if isPlatformAdmin();

      allow update: if isPlatformAdmin()
        || (
          isShopAdmin()
          && userDoc().companyId == companyId
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['settings', 'updatedAt'])
        );

      match /jobs/{jobId} {
        allow read, write: if isPlatformAdmin() || sameCompany(companyId);
      }
    }
  }
}
