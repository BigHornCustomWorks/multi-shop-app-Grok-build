rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function accountActive() {
      return signedIn() && (
        !userExists()
        || !('active' in userDoc())
        || userDoc().active != false
      );
    }

    function isPlatformAdmin() {
      return accountActive()
        && userExists()
        && userDoc().role == 'platform_admin';
    }

    /** Shop Owner (shop_admin) — team management in Settings */
    function isShopAdmin() {
      return accountActive()
        && userExists()
        && userDoc().role == 'shop_admin'
        && userDoc().companyId is string
        && userDoc().companyId.size() > 0;
    }

    function isPartsManager() {
      return accountActive()
        && userExists()
        && userDoc().role == 'parts_manager'
        && userDoc().companyId is string
        && userDoc().companyId.size() > 0;
    }

    function sameCompany(companyId) {
      return accountActive()
        && userExists()
        && userDoc().companyId is string
        && userDoc().companyId == companyId;
    }

    function canUsePartRequests(companyId) {
      return isPlatformAdmin() || sameCompany(companyId);
    }

    /**
     * Owner may manage staff in their shop only:
     * - target is same company (or being removed)
     * - cannot touch platform_admin or other Owners
     * - cannot promote anyone to shop_admin / platform_admin
     */
    function shopOwnerManagingStaff() {
      return isShopAdmin()
        && resource.data.get('role', '') != 'platform_admin'
        && resource.data.get('role', '') != 'shop_admin'
        && resource.data.get('companyId', '') == userDoc().companyId
        && (
          // Still in shop, or unlinked
          request.resource.data.get('companyId', '') == userDoc().companyId
          || request.resource.data.get('companyId', null) == null
        )
        && (
          // Role stays staff-level only
          !('role' in request.resource.data)
          || request.resource.data.role in ['tech', 'parts_manager']
        );
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId && accountActive();
      allow read, update: if isPlatformAdmin();
      // Shop members can see teammates (for tech assignment lists, not platform admins)
      allow read: if accountActive()
        && userExists()
        && resource.data.get('companyId', '') is string
        && resource.data.get('companyId', '') == userDoc().companyId
        && resource.data.get('role', '') != 'platform_admin';
      allow update: if shopOwnerManagingStaff();
    }

    match /inviteCodes/{code} {
      allow get: if signedIn() && accountActive();
      allow list: if isPlatformAdmin();
      allow create, update, delete: if isPlatformAdmin();
    }

    /**
     * Reverse index: E.164 → companyId for inbound SMS (Phase D).
     * Written by provision/release APIs as platform_admin.
     * Shop staff do not need direct access.
     */
    match /smsNumbers/{numberId} {
      allow read: if isPlatformAdmin();
      allow create, update, delete: if isPlatformAdmin();
    }

    match /companies/{companyId} {
      allow read, list: if signedIn() && accountActive();

      allow create, delete: if isPlatformAdmin();
      allow update: if isPlatformAdmin()
        || (
          isShopAdmin()
          && userDoc().companyId == companyId
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['settings', 'updatedAt'])
        );

      match /jobs/{jobId} {
        allow read, write: if isPlatformAdmin() || sameCompany(companyId);
      }

      match /partRequests/{requestId} {
        allow read, list: if canUsePartRequests(companyId);
        allow create: if canUsePartRequests(companyId);
        allow update: if canUsePartRequests(companyId);
        allow delete: if isPlatformAdmin()
          || isShopAdmin()
          || (isPartsManager() && userDoc().companyId == companyId);
      }
    }
  }
}
