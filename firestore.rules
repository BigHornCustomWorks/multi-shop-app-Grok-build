rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function accountActive() {
      return signedIn() && (
        !userExists()
        || !('active' in userDoc())
        || userDoc().active != false
      );
    }

    function isPlatformAdmin() {
      return accountActive()
        && userExists()
        && userDoc().role == 'platform_admin';
    }

    /** Shop Owner (shop_admin) — team management in Settings */
    function isShopAdmin() {
      return accountActive()
        && userExists()
        && userDoc().role == 'shop_admin'
        && userDoc().companyId is string
        && userDoc().companyId.size() > 0;
    }

    function isPartsManager() {
      return accountActive()
        && userExists()
        && userDoc().role == 'parts_manager'
        && userDoc().companyId is string
        && userDoc().companyId.size() > 0;
    }

    function sameCompany(companyId) {
      return accountActive()
        && userExists()
        && userDoc().companyId is string
        && userDoc().companyId == companyId;
    }

    function canUsePartRequests(companyId) {
      return isPlatformAdmin() || sameCompany(companyId);
    }

    /**
     * Self-service profile fields only. Privileged fields (role, companyId, active)
     * are NEVER client-writable on self — set by platform admin, shop owner (limited),
     * or trusted server (join-shop).
     */
    function selfProfileCreateKeys() {
      return request.resource.data.keys()
        .hasOnly(['email', 'displayName', 'jobFilter', 'createdAt', 'updatedAt']);
    }

    function selfProfileUpdateKeys() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['email', 'displayName', 'jobFilter', 'updatedAt']);
    }

    /**
     * Belt-and-suspenders: even if a key sneaks into the write shape, privileged
     * fields must match the existing doc (create has no prior privileged values —
     * create is blocked from including them via hasOnly).
     */
    function privilegedFieldsUnchanged() {
      return request.resource.data.get('role', null) == resource.data.get('role', null)
        && request.resource.data.get('companyId', null) == resource.data.get('companyId', null)
        && request.resource.data.get('active', null) == resource.data.get('active', null);
    }

    /**
     * Owner may manage staff in their shop only:
     * - target is same company (or being removed)
     * - cannot touch platform_admin or other Owners
     * - cannot promote anyone to shop_admin / platform_admin
     */
    function shopOwnerManagingStaff() {
      return isShopAdmin()
        && resource.data.get('role', '') != 'platform_admin'
        && resource.data.get('role', '') != 'shop_admin'
        && resource.data.get('companyId', '') == userDoc().companyId
        && (
          // Stay in shop, or unlink (companyId cleared)
          request.resource.data.get('companyId', '') == userDoc().companyId
          || request.resource.data.get('companyId', null) == null
        )
        && (
          // Role stays staff-level, or cleared when unlinking
          !('role' in request.resource.data)
          || request.resource.data.role in ['tech', 'parts_manager']
          || (
            request.resource.data.get('companyId', null) == null
            && request.resource.data.get('role', null) == null
          )
        );
    }

    match /users/{userId} {
      // Own profile create: harmless fields only — no role / companyId / active
      allow create: if signedIn()
        && request.auth.uid == userId
        && accountActive()
        && selfProfileCreateKeys();

      // Own profile update: same allowlist; privileged fields must stay unchanged
      allow update: if signedIn()
        && request.auth.uid == userId
        && accountActive()
        && selfProfileUpdateKeys()
        && privilegedFieldsUnchanged();

      allow read: if signedIn() && request.auth.uid == userId && accountActive();

      // Platform admin: full read/update of any user (including privileged fields)
      allow read, update: if isPlatformAdmin();

      // Shop members can see teammates (for tech assignment lists, not platform admins)
      allow read: if accountActive()
        && userExists()
        && resource.data.get('companyId', '') is string
        && resource.data.get('companyId', '') == userDoc().companyId
        && resource.data.get('role', '') != 'platform_admin';

      // Shop owner manages staff (limited roles / same company)
      allow update: if shopOwnerManagingStaff();
    }

    match /inviteCodes/{code} {
      // Still readable by signed-in users (code → companyId only; no Twilio secrets).
      // Join flow uses server join-shop; client does not need this for company docs.
      allow get: if signedIn() && accountActive();
      allow list: if isPlatformAdmin();
      allow create, update, delete: if isPlatformAdmin();
    }

    /**
     * Reverse index: E.164 → companyId for inbound SMS (Phase D).
     * Written by provision/release APIs as platform_admin.
     */
    match /smsNumbers/{numberId} {
      allow read: if isPlatformAdmin();
      allow create, update, delete: if isPlatformAdmin();
    }

    match /companies/{companyId} {
      // Own shop only (or platform admin). No cross-tenant company / Twilio leak.
      allow get: if isPlatformAdmin()
        || (signedIn() && accountActive() && userDoc().companyId == companyId);
      allow list: if isPlatformAdmin();

      allow create, delete: if isPlatformAdmin();
      allow update: if isPlatformAdmin()
        || (
          isShopAdmin()
          && userDoc().companyId == companyId
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['settings', 'updatedAt'])
        );

      match /jobs/{jobId} {
        allow read, write: if isPlatformAdmin() || sameCompany(companyId);
      }

      match /partRequests/{requestId} {
        allow read, list: if canUsePartRequests(companyId);
        allow create: if canUsePartRequests(companyId);
        allow update: if canUsePartRequests(companyId);
        // Shop admin / parts manager must match path companyId (no cross-shop deletes)
        allow delete: if isPlatformAdmin()
          || (isShopAdmin() && userDoc().companyId == companyId)
          || (isPartsManager() && userDoc().companyId == companyId);
      }
    }
  }
}
