# xAI / Grok — AI document scanning
# Preferred on Vercel (server-only, never sent to the phone browser):
# XAI_API_KEY=xai-...
#
# Also works (and is used for local npm run dev if you call xAI from the browser):
VITE_XAI_API_KEY=
#
# Optional vision model override (default: grok-4.5):
# XAI_VISION_MODEL=grok-4.5
# VITE_XAI_VISION_MODEL=grok-4.5

# Firebase web app config (from Project settings → Your apps → Web → Config)
# Set these on Vercel so every phone/computer skips the first-time setup paste screen.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional
# VITE_FIREBASE_MEASUREMENT_ID=

# ── Server only (Vercel env — NEVER prefix with VITE_) ──────────────────────
# Used by /api/send-sms, provision-twilio-number, release-twilio-number.
# Do not put these in the browser .env as VITE_*.
#
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your_primary_auth_token
#
# ONE-TIME migrate only: link existing live number to a shop via Master Control
# “Migrate env number”. Send path does NOT fall back to this — each shop must
# have its own twilioSmsNumber.
# TWILIO_FROM_NUMBER=+15551234567
#
# Paid account: set false or delete so custom SMS text is used
# TWILIO_TRIAL_MODE=false
# TWILIO_TRIAL_TEMPLATE=sms_delivery_updates
#
# Optional instead of auth token:
# TWILIO_API_KEY_SID=SKxxxxxxxx
# TWILIO_API_KEY_SECRET=your_api_key_secret
#
# Twilio Email (POST https://comms.twilio.com/v1/Emails) — verified sender required
# TWILIO_EMAIL_FROM=notifications@yourdomain.com
# TWILIO_EMAIL_FROM_NAME=Custom Shop Management
#
# Same value as VITE_FIREBASE_API_KEY — used to verify the signed-in user:
# FIREBASE_WEB_API_KEY=
# (or leave FIREBASE_WEB_API_KEY unset and set VITE_FIREBASE_API_KEY on Vercel for all envs)
#
# Firestore project id for server REST (company lookup / reverse index):
# FIREBASE_PROJECT_ID=   (or VITE_FIREBASE_PROJECT_ID already set)
#
# Required for POST /api/join-shop (Admin SDK sets companyId + role=tech):
# Paste the full service account JSON as a single-line string, or base64 of that JSON.
# Firebase Console → Project settings → Service accounts → Generate new private key
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
