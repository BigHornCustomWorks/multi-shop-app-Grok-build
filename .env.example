# xAI / Grok API key for AI document scanning
VITE_XAI_API_KEY=

# Firebase web app config (from Project settings → Your apps → Web → Config)
# Set these on Vercel so every phone/computer skips the first-time setup paste screen.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional
# VITE_FIREBASE_MEASUREMENT_ID=
